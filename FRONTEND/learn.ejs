<%- include('header.ejs') %>

    <main class="max-w-3xl mx-auto mt-8 px-4 space-y-8 animate-in fade-in duration-300">
        <div class="text-center space-y-2 mb-10">
            <h1 class="text-4xl font-black text-gray-800">Your Learning Path 🗺️</h1>
            <p class="text-gray-500 font-bold text-lg">Step-by-step to master new skills!</p>
        </div>

        <div id="classSection" class="space-y-4">
            <h2 class="text-xl font-black text-gray-700 flex items-center gap-2">
                <span
                    class="bg-blue-500 text-white w-8 h-8 rounded-full flex items-center justify-center text-sm shadow-[0_3px_0_#1e40af]">1</span>
                Select Your Class
            </h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <% const classes=["6th", "7th" , "8th" , "9th" ]; %>
                    <% classes.forEach(cls=> { %>
                        <button onclick="selectClass('<%= cls %>')"
                            class="btn-chunky btn-white py-4 text-lg w-full text-center">
                            <%= cls %> Grade
                        </button>
                        <% }) %>
            </div>
        </div>

        <div id="subjectSection" class="space-y-4 hidden animate-in slide-in-from-top-4">
            <div class="flex items-center justify-between">
                <h2 class="text-xl font-black text-gray-700 flex items-center gap-2">
                    <span
                        class="bg-blue-500 text-white w-8 h-8 rounded-full flex items-center justify-center text-sm shadow-[0_3px_0_#1e40af]">2</span>
                    Choose a Subject
                </h2>
                <button onclick="goBackToClass()" class="text-blue-500 font-bold hover:underline">⬅ Back</button>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <button onclick="selectSubject('Mathematics')"
                    class="neo-card p-6 flex flex-col items-center justify-center gap-2 group">
                    <span class="text-4xl group-hover:scale-110 transition-transform">📘</span>
                    <span class="font-bold text-gray-700">Math</span>
                </button>
                <button onclick="selectSubject('Science')"
                    class="neo-card p-6 flex flex-col items-center justify-center gap-2 group">
                    <span class="text-4xl group-hover:scale-110 transition-transform">🔬</span>
                    <span class="font-bold text-gray-700">Science</span>
                </button>
                <button onclick="selectSubject('Computer Science')"
                    class="neo-card p-6 flex flex-col items-center justify-center gap-2 group">
                    <span class="text-4xl group-hover:scale-110 transition-transform">💻</span>
                    <span class="font-bold text-gray-700">CS</span>
                </button>
                <button onclick="selectSubject('English')"
                    class="neo-card p-6 flex flex-col items-center justify-center gap-2 group">
                    <span class="text-4xl group-hover:scale-110 transition-transform">📚</span>
                    <span class="font-bold text-gray-700">English</span>
                </button>
            </div>
        </div>

        <div id="chapterSection" class="space-y-4 hidden animate-in slide-in-from-top-4 pb-12">
            <div class="flex items-center justify-between">
                <h2 class="text-xl font-black text-gray-700 flex items-center gap-2">
                    <span
                        class="bg-blue-500 text-white w-8 h-8 rounded-full flex items-center justify-center text-sm shadow-[0_3px_0_#1e40af]">3</span>
                    Let's Learn!
                </h2>
                <button onclick="goBackToSubject()" class="text-blue-500 font-bold hover:underline">⬅ Back</button>
            </div>
            <div id="dynamicChapters" class="space-y-4">
            </div>
        </div>
    </main>

    <script>
        let selectedClass = null;

        function selectClass(cls) {
            selectedClass = cls;
            document.getElementById('classSection').classList.add('hidden');
            document.getElementById('subjectSection').classList.remove('hidden');
        }

        function goBackToClass() {
            document.getElementById('subjectSection').classList.add('hidden');
            document.getElementById('classSection').classList.remove('hidden');
        }

        async function selectSubject(sub) {
            document.getElementById('subjectSection').classList.add('hidden');
            document.getElementById('chapterSection').classList.remove('hidden');

            const container = document.getElementById('dynamicChapters');
            container.innerHTML = '<div class="text-center font-bold text-gray-400 py-10">Loading modules...</div>';

            try {
                const response = await fetch(`/api/content/${selectedClass}/${sub}`);
                const data = await response.json();

                if (data.length === 0) {
                    container.innerHTML = '<div class="text-center font-bold text-gray-500 py-10">Modules coming soon!</div>';
                    return;
                }

                container.innerHTML = data.map(item => {
                    const icon = item.activity_type === 'notes' ? '📖' : item.activity_type === 'quiz' ? '📝' : '🎮';
                    return `
                    <div class="neo-card p-6 flex flex-col sm:flex-row items-center justify-between gap-4">
                        <div class="flex items-center gap-4 w-full">
                            <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center text-3xl border-2 border-gray-200 shadow-[0_4px_0_#e5e7eb]">
                                ${icon}
                            </div>
                            <div>
                                <h3 class="text-xl font-black text-gray-800">${item.chapter_name}</h3>
                                <p class="text-sm font-bold text-gray-400 capitalize">${item.activity_type}</p>
                            </div>
                        </div>
                        <a href="/activity/${item.id}" class="btn-chunky btn-green px-8 py-3 w-full sm:w-auto text-center text-white">Start</a>
                    </div>
                `;
                }).join('');
            } catch (error) {
                container.innerHTML = '<div class="text-center text-red-500 font-bold py-10">Error loading content.</div>';
            }
        }

        function goBackToSubject() {
            document.getElementById('chapterSection').classList.add('hidden');
            document.getElementById('subjectSection').classList.remove('hidden');
        }
    </script>

    <%- include('footer.ejs') %>
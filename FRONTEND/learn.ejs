<%- include('header.ejs') %>

    <section class="intro-section text-center py-5 rounded shadow-sm mx-3 mt-4">
        <div class="container">
            <h2 class="fw-bold">Start Learning 🚀</h2>
            <p class="lead">Select your class and subject to explore interactive modules.</p>
        </div>
    </section>

    <div class="container my-5">
        <section id="classSection">
            <h3 class="mb-4">Select Your Class</h3>
            <div class="row g-4">
                <% const classes=["6th", "7th" , "8th" , "9th" ]; %>
                    <% classes.forEach(cls=> { %>
                        <div class="col-md-4 col-lg-3">
                            <div class="card h-100 text-center shadow-sm cursor-pointer"
                                onclick="selectClass('<%= cls %>')">
                                <div class="card-body">
                                    <div class="display-4">🏫</div>
                                    <h5 class="card-title mt-3">
                                        <%= cls %> Class
                                    </h5>
                                </div>
                            </div>
                        </div>
                        <% }) %>
            </div>
        </section>

        <section id="subjectSection" style="display:none;">
            <button class="btn btn-outline-primary mb-4" onclick="goBackToClass()">⬅ Back to Class</button>
            <h3 class="mb-4">Select Your Subject</h3>
            <div class="row g-4">
                <% const subjects=["Mathematics", "Science" , "Computer Science" , "English" ]; %>
                    <% subjects.forEach(sub=> { %>
                        <div class="col-md-4 col-lg-3">
                            <div class="card h-100 text-center shadow-sm cursor-pointer"
                                onclick="selectSubject('<%= sub %>')">
                                <div class="card-body">
                                    <div class="display-4">📘</div>
                                    <h5 class="card-title mt-3">
                                        <%= sub %>
                                    </h5>
                                </div>
                            </div>
                        </div>
                        <% }) %>
            </div>
        </section>

        <section id="chapterSection" style="display:none;">
            <button class="btn btn-outline-primary mb-4" onclick="goBackToSubject()">⬅ Back to Subject</button>
            <h3 class="mb-4">Available Modules</h3>

            <div class="row g-4" id="dynamicChapters">
            </div>
        </section>
    </div>

    <script>
        let selectedClass = null;
        let selectedSubject = null;

        function selectClass(cls) {
            selectedClass = cls;
            document.getElementById('classSection').style.display = 'none';
            document.getElementById('subjectSection').style.display = 'block';
        }

        function goBackToClass() {
            document.getElementById('subjectSection').style.display = 'none';
            document.getElementById('classSection').style.display = 'block';
        }

        async function selectSubject(sub) {
            selectedSubject = sub;

            // Hide Subject view, show Chapter view
            document.getElementById('subjectSection').style.display = 'none';
            document.getElementById('chapterSection').style.display = 'block';

            const chapterContainer = document.getElementById('dynamicChapters');
            chapterContainer.innerHTML = '<div class="col-12 text-center"><h5>Loading content... ⏳</h5></div>';

            try {
                // Fetch from our new Express API
                const response = await fetch(`/api/content/${selectedClass}/${selectedSubject}`);
                const activitiesData = await response.json();

                chapterContainer.innerHTML = ''; // Clear loading text

                if (activitiesData.length === 0) {
                    chapterContainer.innerHTML = '<div class="col-12 text-center"><p class="text-muted fs-5">New content coming soon for this subject!</p></div>';
                } else {
                    activitiesData.forEach(item => {
                        // Assign specific icons and colors based on activity type
                        let icon = item.activity_type === 'notes' ? '📖' : item.activity_type === 'quiz' ? '📝' : '🎮';
                        let colorClass = item.activity_type === 'notes' ? 'text-primary' : item.activity_type === 'quiz' ? 'text-success' : 'text-warning';

                        // Inject the card directly linking to the /activity/:id route
                        chapterContainer.innerHTML += `
                        <div class="col-md-4 col-lg-3">
                            <div class="card h-100 text-center shadow-sm cursor-pointer" onclick="window.location.href='/activity/${item.id}'">
                                <div class="card-body">
                                    <div class="display-4">${icon}</div>
                                    <h6 class="mt-3 text-muted" style="font-size: 0.9rem;">${item.chapter_name}</h6>
                                    <h5 class="card-title text-capitalize fw-bold mt-2 ${colorClass}">${item.activity_type}</h5>
                                </div>
                            </div>
                        </div>
                    `;
                    });
                }
            } catch (error) {
                console.error("Error loading content:", error);
                chapterContainer.innerHTML = '<div class="col-12 text-center text-danger"><p>Failed to load content. Please check your database connection.</p></div>';
            }
        }

        function goBackToSubject() {
            document.getElementById('chapterSection').style.display = 'none';
            document.getElementById('subjectSection').style.display = 'block';
        }
    </script>

    <%- include('footer.ejs') %>
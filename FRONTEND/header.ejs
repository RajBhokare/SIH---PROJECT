<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>EduQuest</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="min-h-screen pb-20 text-gray-700">

    <nav
        class="glass-nav sticky top-4 z-50 px-6 py-4 flex items-center justify-between shadow-sm rounded-full mx-auto max-w-5xl mt-4">
        <a href="/" class="flex items-center gap-2 cursor-pointer">
            <div class="text-3xl font-black text-blue-500 tracking-tight flex items-center gap-1">
                EduQuest
                <span class="text-2xl bounce-icon">📐</span>
                <span class="text-2xl bounce-icon">🧬</span>
                <span class="text-2xl bounce-icon">💻</span>
            </div>
        </a>

        <div class="hidden md:flex items-center gap-8 font-bold text-gray-500">
            <a href="/" class="hover:text-blue-500 transition-colors">Home</a>
            <a href="/learn" class="hover:text-blue-500 transition-colors">Learn</a>
            <a href="/about" class="hover:text-blue-500 transition-colors">About</a>
            <a href="/contact" class="hover:text-blue-500 transition-colors">Contact</a>
        </div>

        <div id="authContainer" class="flex items-center gap-3">
        </div>
    </nav>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const user = JSON.parse(localStorage.getItem("loggedInUser"));
            const authContainer = document.getElementById("authContainer");

            if (user) {
                // UI for Logged In User
                authContainer.innerHTML = `
                    <div class="flex items-center gap-4">
                        <a href="/dashboard" class="flex items-center gap-2 font-bold text-gray-700 hover:text-blue-500">
                            <div class="w-10 h-10 bg-yellow-400 rounded-full flex items-center justify-center border-2 border-white shadow-md">👨‍🎓</div>
                            <span class="hidden sm:inline">My Account</span>
                        </a>
                        <button onclick="logoutUser()" class="text-gray-400 hover:text-red-500 font-bold transition-colors">Logout</button>
                    </div>
                `;
            } else {
                // UI for Logged Out User
                authContainer.innerHTML = `
                    <a href="/login" class="font-bold text-gray-500 hover:text-blue-500">Login</a>
                    <a href="/signup" class="btn-chunky btn-blue px-6 py-2 text-sm text-white">Sign Up</a>
                `;
            }
        });

        function logoutUser() {
            localStorage.removeItem("loggedInUser");
            window.location.href = "/";
        }
    </script>
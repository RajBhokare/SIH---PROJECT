            <script>
                let currentSlide = 0;
                const carousel = document.getElementById('featureCarousel');
                const totalSlides = document.querySelectorAll('.feature-item').length;

                function moveCarousel(direction) {
                    const visibleSlides = window.innerWidth >= 768 ? 3 : 1;
                    const maxSlide = totalSlides - visibleSlides;

                    currentSlide += direction;

                    if (currentSlide < 0) currentSlide = maxSlide;
                    if (currentSlide > maxSlide) currentSlide = 0;

                    const offset = currentSlide * (100 / visibleSlides);
                    carousel.style.transform = `translateX(-${offset}%)`;
                }

                // Auto-slide every 5 seconds
                setInterval(() => moveCarousel(1), 5000);
            </script>

<%- include('header.ejs') %>

    <main class="max-w-5xl mx-auto mt-8 px-4">
        <section class="text-center py-16 space-y-6">
            <h1 class="text-5xl md:text-7xl font-black text-gray-800 tracking-tight">
                Free Classes for <br /> Students <span class="text-blue-500">🚀</span>
            </h1>
            <p class="text-xl text-gray-500 font-semibold max-w-2xl mx-auto">
                Learn Math, Science, and more with fun games and interactive quizzes. Education made easy and accessible
                for everyone!
            </p>
            <div class="pt-6">
                <a href="/learn"
                    class="btn-chunky btn-green px-10 py-4 text-xl inline-flex items-center gap-2 text-white">
                    Start Learning Now ➡
                </a>
            </div>
        </section>

        <section class="max-w-4xl mx-auto mt-12">
            <div class="flex items-center justify-between mb-8">
                <h2 class="text-3xl font-black text-gray-800">Popular Courses</h2>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
                <a href="/learn" class="neo-card p-6 flex flex-col items-center text-center">
                    <div
                        class="w-20 h-20 bg-blue-100 rounded-2xl flex items-center justify-center text-4xl mb-4 border-2 border-white shadow-sm">
                        📘</div>
                    <h3 class="text-xl font-bold text-blue-600">Mathematics</h3>
                </a>

                <a href="/learn" class="neo-card p-6 flex flex-col items-center text-center">
                    <div
                        class="w-20 h-20 bg-green-100 rounded-2xl flex items-center justify-center text-4xl mb-4 border-2 border-white shadow-sm">
                        🔬</div>
                    <h3 class="text-xl font-bold text-green-600">Science</h3>
                </a>

                <a href="/learn" class="neo-card p-6 flex flex-col items-center text-center">
                    <div
                        class="w-20 h-20 bg-purple-100 rounded-2xl flex items-center justify-center text-4xl mb-4 border-2 border-white shadow-sm">
                        💻</div>
                    <h3 class="text-xl font-bold text-purple-600">Computer Science</h3>
                </a>

                <a href="/learn" class="neo-card p-6 flex flex-col items-center text-center">
                    <div
                        class="w-20 h-20 bg-yellow-100 rounded-2xl flex items-center justify-center text-4xl mb-4 border-2 border-white shadow-sm">
                        📚</div>
                    <h3 class="text-xl font-bold text-yellow-600">English</h3>
                </a>
            </div>
            <section class="max-w-5xl mx-auto mt-16 px-4">
                <h2 class="text-3xl font-black text-gray-800 mb-8 text-center">Supercharged Features ⚡</h2>
            
                <div class="relative overflow-hidden py-4">
                    <div class="flex transition-transform duration-500 ease-in-out" id="featureCarousel">
                        <div class="min-w-full md:min-w-[33.33%] px-3">
                            <div class="neo-card p-8 flex flex-col items-center text-center h-full feature-item">
                                <div class="text-5xl mb-4 bounce-icon">🗣️</div>
                                <h4 class="text-xl font-extrabold mb-2">Read Aloud</h4>
                                <p class="text-gray-500 font-bold text-sm">Text-to-speech for better accessibility in rural areas.
                                </p>
                            </div>
                        </div>
                        <div class="min-w-full md:min-w-[33.33%] px-3">
                            <div class="neo-card p-8 flex flex-col items-center text-center h-full feature-item">
                                <div class="text-5xl mb-4 bounce-icon">🌐</div>
                                <h4 class="text-xl font-extrabold mb-2">Regional Support</h4>
                                <p class="text-gray-500 font-bold text-sm">Switch between Hindi, Marathi, and English instantly.</p>
                            </div>
                        </div>
                        <div class="min-w-full md:min-w-[33.33%] px-3">
                            <div class="neo-card p-8 flex flex-col items-center text-center h-full feature-item">
                                <div class="text-5xl mb-4 bounce-icon">📉</div>
                                <h4 class="text-xl font-extrabold mb-2">Low Data Mode</h4>
                                <p class="text-gray-500 font-bold text-sm">Optimized for 2G/3G networks with light assets.</p>
                            </div>
                        </div>
                        <div class="min-w-full md:min-w-[33.33%] px-3">
                            <div class="neo-card p-8 flex flex-col items-center text-center h-full feature-item">
                                <div class="text-5xl mb-4 bounce-icon">🏅</div>
                                <h4 class="text-xl font-extrabold mb-2">Smart Badges</h4>
                                <p class="text-gray-500 font-bold text-sm">Earn unique badges for daily learning streaks.</p>
                            </div>
                        </div>
                    </div>
            
                    <button onclick="moveCarousel(-1)"
                        class="absolute left-0 top-1/2 -translate-y-1/2 btn-chunky btn-white p-2 rounded-full">⬅</button>
                    <button onclick="moveCarousel(1)"
                        class="absolute right-0 top-1/2 -translate-y-1/2 btn-chunky btn-white p-2 rounded-full">➡</button>
                </div>
            </section>
            
            <script>
                let currentSlide = 0;
                const carousel = document.getElementById('featureCarousel');
                const totalSlides = document.querySelectorAll('.feature-item').length;

                function moveCarousel(direction) {
                    const visibleSlides = window.innerWidth >= 768 ? 3 : 1;
                    const maxSlide = totalSlides - visibleSlides;

                    currentSlide += direction;

                    if (currentSlide < 0) currentSlide = maxSlide;
                    if (currentSlide > maxSlide) currentSlide = 0;

                    const offset = currentSlide * (100 / visibleSlides);
                    carousel.style.transform = `translateX(-${offset}%)`;
                }

                // Auto-slide every 5 seconds
                setInterval(() => moveCarousel(1), 5000);
            </script>
        </section>
    </main>

    <%- include('footer.ejs') %>
<%- include('header.ejs') %>

    <section class="intro-section text-center py-5 rounded shadow-sm mx-3 mt-4">
        <h2 id="welcomeText" class="fw-bold">Welcome!</h2>
        <p id="subtitleText" class="lead">Your learning journey continues here.</p>
    </section>

    <div class="container my-5">
        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h4 class="card-title text-primary">🏆 Your Rank: Scholar</h4>
                        <p class="mb-1">Next rank in <strong id="pointsNeeded">150</strong> points</p>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar bg-warning progress-bar-striped progress-bar-animated"
                                role="progressbar" style="width: 35%;" aria-valuenow="35" aria-valuemin="0"
                                aria-valuemax="100" id="xpBar">35%</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <h3 class="mb-3">Your Stats</h3>
        <div class="row g-4">
            <div class="col-md-3">
                <div class="card h-100 text-center shadow-sm p-3">
                    <h1 class="display-4" id="completedLessons">0</h1>
                    <p class="text-muted mb-0">Lessons</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 text-center shadow-sm p-3">
                    <h1 class="display-4 text-success" id="quizzesTaken">0</h1>
                    <p class="text-muted mb-0">Quizzes</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 text-center shadow-sm p-3">
                    <h1 class="display-4 text-warning" id="pointsEarned">0</h1>
                    <p class="text-muted mb-0">Points</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 text-center shadow-sm p-3">
                    <div class="display-4 mb-2">🏅</div>
                    <p class="text-muted mb-0"><span id="badgesEarned" class="fw-bold">0</span> Badges</p>
                </div>
            </div>
        </div>

        <div class="text-center mt-5">
            <button onclick="logout()" class="btn btn-danger px-4 py-2">Logout</button>
        </div>
    </div>

<script>
    document.addEventListener("DOMContentLoaded", async () => {
        // 1. Check if user is logged in locally
        const localUser = JSON.parse(localStorage.getItem("loggedInUser"));
        if (!localUser) {
            window.location.href = "/login";
            return;
        }

        // 2. Fetch fresh synced data from the MySQL Database
        try {
            const response = await fetch(`/api/user/${localUser.id}`);
            if (response.ok) {
                const freshUserData = await response.json();

                // Update local storage so it stays perfectly synced
                localStorage.setItem("loggedInUser", JSON.stringify(freshUserData));

                // 3. Render the dynamic data on the screen
                document.getElementById("welcomeText").textContent = `Welcome, ${freshUserData.name} 👋`;
                document.getElementById("completedLessons").textContent = freshUserData.lessons || 0;
                document.getElementById("quizzesTaken").textContent = freshUserData.quizzesTaken || 0;

                // Gamification Math
                const points = freshUserData.points || 0;
                document.getElementById("pointsEarned").textContent = points;
                document.getElementById("badgesEarned").textContent = freshUserData.badges || 0;

                const xpPercentage = Math.min((points / 200) * 100, 100);
                document.getElementById("xpBar").style.width = `${xpPercentage}%`;
                document.getElementById("xpBar").textContent = `${points} XP`;

                let pointsNeeded = 200 - points;
                if (pointsNeeded < 0) pointsNeeded = 0;
                document.getElementById("pointsNeeded").textContent = pointsNeeded;
            } else {
                console.error("Failed to sync user data from server");
            }
        } catch (error) {
            console.error("Error fetching user data:", error);
        }
    });
</script>

    <%- include('footer.ejs') %>